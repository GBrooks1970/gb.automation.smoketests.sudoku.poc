# Stack dependencies — matches any Stack directory at any depth
node_modules/
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/

# Compiled TypeScript output — matches any Stack directory at any depth
dist/

# .NET build output — matches any Stack directory at any depth
bin/
obj/

# Batch script text output
/.batch/output/*.txt

# Test execution results
/.results/
**/.results/

# Serenity BDD living documentation artifacts
.results/serenity/
**/.results/serenity/
