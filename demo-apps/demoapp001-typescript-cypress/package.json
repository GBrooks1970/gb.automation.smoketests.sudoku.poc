{
  "name": "sudoku-solver-demo",
  "version": "1.0.0",
  "description": "Sudoku solver implementing basic solving techniques",
  "main": "dist/index.js",
  "scripts": {
    "start": "ts-node app_src/index.ts",
    "start:api": "ts-node app_src/server/index.ts",
    "build": "tsc",
    "run": "node dist/index.js",
    "lint": "eslint app_src/**/*.ts",
    "format": "prettier --write app_src/**/*.ts",
    "format:check": "prettier --check app_src/**/*.ts",
    "test": "cucumber-js --config tooling/cucumber.js",
    "test:api": "ts-node tests/api/api.integration.ts"
  },
  "keywords": [
    "sudoku",
    "solver",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.3",
    "@cucumber/pretty-formatter": "^3.3.0",
    "@serenity-js/assertions": "^3.43.2",
    "@serenity-js/core": "^3.43.2",
    "@serenity-js/cucumber": "^3.43.2",
    "@serenity-js/serenity-bdd": "^3.43.2",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}
